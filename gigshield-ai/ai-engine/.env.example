# Paste your live weather provider key here.
WEATHER_API_KEY=PASTE_YOUR_WEATHER_API_KEY_HERE

# Indian API weather base URL.
WEATHER_API_BASE_URL=https://weather.indianapi.in

# Default city if no city is sent from the frontend.
DEFAULT_WEATHER_CITY=Bengaluru

# Optional timeout in seconds.
WEATHER_API_TIMEOUT_SECONDS=10

# Optional: absolute path to your trained next destination model.
NEXT_LOCATION_MODEL_PATH=E:/Downloads/next_location_model.pkl

# Optional: absolute path to the destination lookup CSV used to decode predictions.
NEXT_LOCATION_REFERENCE_PATH=F:/guide/gigshield-ai/ai-engine/data/next_location_reference.csv
