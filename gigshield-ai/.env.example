# GigShield full-stack environment

# Frontend
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_FLASK_API_URL=http://localhost:8000

# Backend
NODE_ENV=development
PORT=5000
JWT_SECRET=change-this-to-a-strong-random-string
JWT_EXPIRES_IN=7d
LOG_LEVEL=debug

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gigshield
DB_USER=postgres
DB_PASSWORD=postgres
REDIS_URL=redis://localhost:6379

# Payments
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=change-me

# AI engine
AI_ENGINE_URL=http://localhost:8000
AI_ENGINE_TIMEOUT_MS=10000
WEATHER_API_KEY=PASTE_YOUR_WEATHER_API_KEY_HERE
WEATHER_API_BASE_URL=https://weather.indianapi.in
DEFAULT_WEATHER_CITY=Bengaluru
LOCATION_MODEL_PATH=
LOCATION_REFERENCE_PATH=
