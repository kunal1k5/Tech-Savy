{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm --prefix gigshield-ai/frontend ci",
  "buildCommand": "npm --prefix gigshield-ai/frontend run build",
  "outputDirectory": "gigshield-ai/frontend/build",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
