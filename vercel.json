{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd gigshield-ai/frontend && npm ci --legacy-peer-deps",
  "buildCommand": "cd gigshield-ai/frontend && npm run build",
  "outputDirectory": "gigshield-ai/frontend/build",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
